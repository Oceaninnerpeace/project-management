    "vue": "^3.4.38",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@rjgfny/config": "^0.1.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "eslint": "^8.57.0",
